generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  WORKER
  CLIENT
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING_ACCOUNT
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
}

model Salon {
  id        String    @id
  name      String
  subdomain String    @unique
  createdAt DateTime
  users     User[]
  services  Service[]
  products  Product[]
  bookings  Booking[]
  orders    Order[]
}

model User {
  id            String         @id
  email         String         @unique
  password      String
  name          String
  phone         String
  role          Role
  salonId       String
  createdAt     DateTime
  salon         Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile?
  bookings      Booking[]      @relation("ClientBookings")
  orders        Order[]        @relation("ClientOrders")
}

model WorkerProfile {
  id            String    @id
  userId        String    @unique
  commissionPct Float
  isAvailable   Boolean
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[]
}

model Service {
  id              String           @id
  salonId         String
  name            String
  duration        Int
  price           Decimal          @db.Decimal(10, 2)
  salon           Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model Product {
  id         String   @id
  salonId    String
  name       String
  description String?
  imageUrl   String?
  price      Decimal  @db.Decimal(10, 2)
  stockCount Int
  salon      Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Order {
  id          String      @id
  salonId     String
  clientId    String
  status      OrderStatus
  totalAmount Decimal     @db.Decimal(10, 2)
  createdAt   DateTime
  salon       Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client      User        @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Cascade)
  items       OrderItem[]
}

model OrderItem {
  id        String   @id
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Booking {
  id               String            @id
  salonId          String
  clientId         String
  workerId         String
  serviceId        String
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus
  mpesaCheckoutId  String?           @unique
  mpesaReceiptCode String?           @unique
  createdAt        DateTime
  salon            Salon             @relation(fields: [salonId], references: [id], onDelete: Cascade)
  client           User              @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  worker           WorkerProfile     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  earnedCommission EarnedCommission?
  review           Review?
}

model EarnedCommission {
  id        String   @id
  bookingId String   @unique
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
